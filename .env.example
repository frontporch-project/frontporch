DJANGO_SECRET_KEY=replace-with-a-private-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=100.64.0.10,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://100.64.0.10:8000
FRONTPORCH_DEFAULT_PHONE_REGION=US
FRONTPORCH_WEB_BIND_IP=100.64.0.10
FRONTPORCH_WEB_PORT=8000
TZ=America/New_York

POSTGRES_DB=frontporch
POSTGRES_USER=frontporch
POSTGRES_PASSWORD=replace-with-a-private-password
POSTGRES_VOLUME_NAME=frontporch-postgres

ASTERISK_ETC_DIR=./asterisk/etc
ASTERISK_CONF_D_DIR=./asterisk/etc/conf.d
ASTERISK_LOG_DIR=./asterisk/logs
ASTERISK_SPOOL_DIR=./asterisk/spool
ASTERISK_AUTO_APPLY_CONFIG=true
ASTERISK_AMI_HOST=100.64.0.10
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=frontporch-reload
ASTERISK_AMI_PASSWORD=replace-with-a-private-password
ASTERISK_AMI_TIMEOUT=5

# Use an authorized outbound caller ID for your SIP trunk.
# For VoIP.ms this is normally a 10-digit DID on the account, without +1.
ASTERISK_OUTBOUND_CALLER_ID=2025550199

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
